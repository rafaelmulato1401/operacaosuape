rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados operacionais — qualquer usuário autenticado pode ler e escrever
    match /entradas/{doc} {
      allow read, write: if request.auth != null;
    }
    match /saidas_diversos/{doc} {
      allow read, write: if request.auth != null;
    }
    match /saidas_rodo/{doc} {
      allow read, write: if request.auth != null;
    }

    // Perfis de usuário
    match /users/{uid} {
      // Qualquer usuário autenticado pode ler perfis
      allow read: if request.auth != null;
      // Apenas o próprio usuário ou um master pode escrever
      allow write: if request.auth != null && (
        request.auth.uid == uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'master'
      );
    }
  }
}
